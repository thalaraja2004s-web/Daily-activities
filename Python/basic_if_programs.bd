"""
1. Program to check if a number is positive or negative
"""
num = int(input("Enter number: "))

if num >= 0:
    print("Positive")
else:
    print("Negative")


"""
2. Program to check whether a number is even or odd
"""
num = int(input("\nEnter number: "))

if num % 2 == 0:
    print("Even number")
else:
    print("Odd number")


"""
3. Program to check the largest of two numbers
"""
a = int(input("\nEnter first number: "))
b = int(input("Enter second number: "))

if a > b:
    print("Largest number is:", a)
else:
    print("Largest number is:", b)


"""
4. Program to find the largest of three numbers
"""
a = int(input("\nEnter first number: "))
b = int(input("Enter second number: "))
c = int(input("Enter third number: "))

if a > b and a > c:
    print("Largest number is:", a)
elif b > c:
    print("Largest number is:", b)
else:
    print("Largest number is:", c)


"""
5. Program to check whether a number is divisible by 5 and 11
"""
num = int(input("\nEnter the value: "))

if num % 5 == 0 and num % 11 == 0:
    print("The given value is divisible by 5 and 11")
else:
    print("The given value is not divisible by 5 and 11")


"""
6. Program to check whether a year is a leap year
"""
year = int(input("\nEnter year: "))

if year % 4 == 0:
    print("Leap Year")
else:
    print("Not Leap Year")


"""
7. Program to check whether a character is vowel or consonant
"""
ch = input("\nEnter character: ")

if ch in "aeiouAEIOU":
    print("Vowel")
else:
    print("Consonant")


"""
8. Program to check whether a number is multiple of 3 and 7
"""
num = int(input("\nEnter number: "))

if num % 3 == 0 and num % 7 == 0:
    print("Multiple")
else:
    print("Not Multiple")


"""
9. Program to check whether a number is a three-digit number
"""
num = int(input("\nEnter number: "))

if 100 <= num <= 999:
    print("This is a three-digit number")
else:
    print("This is not a three-digit number")


"""
10. Program to check whether a number is greater than 100
"""
num = int(input("\nEnter number: "))

if num > 100:
    print("This number is greater than 100")
else:
    print("This number is not greater than 100")
